  "version": "1.2.5",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "sync:android": "node scripts/syncAndroidVersion.js",
    "postversion": "node scripts/syncAndroidVersion.js && node -e \"const fs=require('fs');const pkg=require('./package.json');const app=require('./app.json');app.expo.version=pkg.version;fs.writeFileSync('./app.json',JSON.stringify(app,null,2)+'\\n');\""
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.26",
    "@react-navigation/stack": "^7.4.8",
    "axios": "^1.13.2",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.33",
    "expo-application": "^7.0.8",
    "expo-device": "^8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "^17.0.10",
    "expo-location": "^19.0.8",
    "expo-notifications": "^55.0.11",
    "expo-print": "~15.0.0",
    "expo-sharing": "~12.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "eas-cli": "^13.4.2"
  },
  "private": true
}
